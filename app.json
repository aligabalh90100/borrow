{
  "expo": {
    "name": "borrow",
    "slug": "borrow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/borrow.png",
    "scheme": "borrow",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.borrow"
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.borrow",
      "adaptiveIcon": {
        "backgroundColor": "#7659FB",
        "foregroundImage": "./assets//images/borrow-android.png"
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/borrow-android.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#7659FB",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-dev-client",
        {
          "launchMode": "most-recent"
        }
      ],
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": true,
          "faceIDPermission": "Allow $(PRODUCT_NAME) to access your Face ID biometric data."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
